{
  "name": "hapa/platform",
  "description": "Piattaforma proprietaria per anagrafiche clienti e ordini, marketplace, Space API, magazzino, corrieri GLS/BRT e futuro B2C.",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.4",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "ext-redis": "*",
    "ext-sockets": "*",
    "monolog/monolog": "^3.7",
    "php-amqplib/php-amqplib": "^3.7",
    "robmorgan/phinx": "^0.16.6",
    "symfony/console": "^7.2",
    "symfony/dependency-injection": "^7.4",
    "symfony/dotenv": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/routing": "^7.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Hapa\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Hapa\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "architecture:check": "php scripts/check-architecture.php",
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration",
    "analyse": "phpstan analyse",
    "security:audit": "composer audit --locked",
    "ci:fast": [
      "@architecture:check",
      "@test",
      "@analyse"
    ],
    "ci:full": [
      "composer validate --strict",
      "@security:audit",
      "@ci:fast"
    ],
    "ci": "@ci:fast"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
