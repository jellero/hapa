#!/usr/bin/env php
<?php

declare(strict_types=1);

use Hapa\Core\Bootstrap;
use Hapa\Modules\Space\Application\SpaceCatalogConsumeCommand;
use Symfony\Component\Console\Application;

$basePath = dirname(__DIR__);
require $basePath . '/vendor/autoload.php';

$bootstrap = Bootstrap::initialize($basePath);

$application = new Application('HAPA', '0.5.0');
$application->add($bootstrap->systemCheckCommand());
$application->add($bootstrap->outboxRelayCommand());
$spaceCatalogConsumer = $bootstrap->container()->get(SpaceCatalogConsumeCommand::class);
if (!$spaceCatalogConsumer instanceof SpaceCatalogConsumeCommand) {
    throw new RuntimeException('Il container non ha prodotto il consumer catalogo Space.');
}
$application->add($spaceCatalogConsumer);
$application->run();
