#!/usr/bin/env php
<?php

declare(strict_types=1);

use Hapa\Core\Bootstrap\Bootstrap;
use Hapa\Core\Console\SystemCheckCommand;
use Symfony\Component\Console\Application;

$basePath = dirname(__DIR__);
require $basePath . '/vendor/autoload.php';

$context = (new Bootstrap())->initialize($basePath);

$application = new Application('HAPA', '0.3.0');
$application->add(new SystemCheckCommand($context->readiness));
$application->run();
