APP_ENV=production
APP_DEBUG=false
APP_URL=https://hapa.example.com
APP_TIMEZONE=Europe/Rome
TRUSTED_PROXIES=REMOTE_ADDR
HAPA_HTTP_BIND=127.0.0.1
HAPA_HTTP_PORT=8080
IMAGE_TAG=REPLACE_WITH_COMMIT_SHA

# In produzione usare riferimenti completi con digest sha256.
PHP_BASE_IMAGE=php:8.4-fpm-alpine@sha256:REPLACE_WITH_DIGEST
COMPOSER_BASE_IMAGE=composer:2@sha256:REPLACE_WITH_DIGEST
NGINX_BASE_IMAGE=nginx:1.27-alpine@sha256:REPLACE_WITH_DIGEST
REDIS_BASE_IMAGE=redis:7.4-alpine@sha256:REPLACE_WITH_DIGEST
POSTGRES_IMAGE=postgres:17-alpine@sha256:REPLACE_WITH_DIGEST

DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hapa
DB_USERNAME=hapa
DB_PASSWORD_FILE=./secrets/db_password.txt
DB_CONNECT_TIMEOUT=5

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD_FILE=./secrets/redis_password.txt
REDIS_CONNECT_TIMEOUT=2.0

LOG_LEVEL=info
