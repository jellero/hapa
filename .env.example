# Configurazione esclusivamente locale
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Europe/Rome

DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hapa
DB_USERNAME=hapa
DB_PASSWORD=hapa-local-change-me
DB_CONNECT_TIMEOUT=5

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=hapa-local-redis-change-me
REDIS_CONNECT_TIMEOUT=2.0

HAPA_MESSAGING_NETWORK=hapa-messaging

# Publisher HAPA -> RabbitMQ
RABBITMQ_ENABLED=false
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USERNAME=hapa_automation
RABBITMQ_PASSWORD=hapa-automation-rabbit-change-me
RABBITMQ_EXCHANGE=hapa.events
RABBITMQ_CONNECT_TIMEOUT=5.0
RABBITMQ_READ_WRITE_TIMEOUT=30.0
RABBITMQ_HEARTBEAT=30

OUTBOX_RELAY_WORKER_ID=hapa-relay-local-1
OUTBOX_RELAY_BATCH_SIZE=50
OUTBOX_RELAY_LOCK_TIMEOUT_SECONDS=300
OUTBOX_RELAY_RETRY_BASE_SECONDS=30
OUTBOX_RELAY_RETRY_MAX_SECONDS=3600

# Consumer RabbitMQ -> HAPA. In locale può usare lo stesso account del broker automation.
RABBITMQ_CONSUMER_ENABLED=false
RABBITMQ_CONSUMER_HOST=rabbitmq
RABBITMQ_CONSUMER_PORT=5672
RABBITMQ_CONSUMER_VHOST=/
RABBITMQ_CONSUMER_USERNAME=hapa_automation
RABBITMQ_CONSUMER_PASSWORD=hapa-automation-rabbit-change-me
RABBITMQ_CONSUMER_EXCHANGE=hapa.events
RABBITMQ_CONSUMER_DEAD_EXCHANGE=hapa.dead
RABBITMQ_CONSUMER_QUEUE=hapa.inbound.events
RABBITMQ_CONSUMER_DEAD_QUEUE=hapa.inbound.dead
RABBITMQ_CONSUMER_BINDINGS=integration.transport.#,space.catalog.item.observed,space.purchase_order.#,marketplace.order.observed,marketplace.offer.#
RABBITMQ_CONSUMER_CONNECT_TIMEOUT=5.0
RABBITMQ_CONSUMER_READ_WRITE_TIMEOUT=30.0
RABBITMQ_CONSUMER_HEARTBEAT=30
RABBITMQ_CONSUMER_MAX_ATTEMPTS=5

INTEGRATION_CONNECT_TIMEOUT=5.0
INTEGRATION_REQUEST_TIMEOUT=30.0
INTEGRATION_MAX_RESPONSE_BYTES=2097152

# Canale sincrono interno per credenziali provider write-only.
AUTOMATION_ADMIN_API_URL=http://hapa-automation-admin-api:8091
AUTOMATION_ADMIN_API_TOKEN=hapa-automation-local-admin-token-change-me
AUTOMATION_ADMIN_API_TIMEOUT=10.0

LOG_LEVEL=debug
